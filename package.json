{
  "name": "@topogram/generator-sveltekit-web",
  "version": "0.1.20",
  "description": "Package-backed Topogram generator for SvelteKit web apps.",
  "license": "UNLICENSED",
  "private": false,
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/attebury/topogram-generator-sveltekit-web.git"
  },
  "main": "index.cjs",
  "files": [
    "index.cjs",
    "topogram-generator.json",
    "README.md"
  ],
  "scripts": {
    "check": "node ./scripts/check-generator.mjs && node ./scripts/verify.mjs",
    "pack:check": "npm pack --dry-run",
    "docs:rag:build": "node ./scripts/build-llms-full.mjs",
    "docs:rag:check": "node ./scripts/verify-docs-rag.mjs",
    "security:secrets": "node ./scripts/run-secret-scan.mjs",
    "release:preflight": "npm run check && npm run docs:rag:check && npm run pack:check && npm run security:secrets"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "@topogram/cli": "^0.3.100"
  }
}
