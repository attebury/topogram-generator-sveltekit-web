{
  "id": "@topogram/generator-sveltekit-web",
  "version": "1",
  "surface": "web",
  "inputs": [
    "ui-surface-contract",
    "api-contracts"
  ],
  "outputs": [
    "web-app",
    "generation-coverage"
  ],
  "stack": {
    "runtime": "node",
    "framework": "sveltekit",
    "language": "typescript"
  },
  "capabilities": {
    "routes": true,
    "coverage": true,
    "widgets": true
  },
  "source": "package",
  "package": "@topogram/generator-sveltekit-web",
  "runtimeKinds": [
    "web_surface"
  ],
  "projectionTypes": [
    "web_surface"
  ],
  "widgetSupport": {
    "patterns": [
      "summary_stats",
      "board_view",
      "calendar_view",
      "resource_table",
      "data_grid_view"
    ],
    "behaviors": [
      "selection",
      "sorting",
      "filtering",
      "search",
      "pagination",
      "bulk_action",
      "optimistic_update"
    ],
    "unsupported": "error"
  }
}
